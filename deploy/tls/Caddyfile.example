# Caddy 最小可行配置：前置终止 TLS，h2c 回源给明文的 rclaude-server。
# 详见 docs/design/caddy-tls-termination.md。install-caddy.sh 会用环境变量
# 渲染出真正下发到 <remote>:/etc/caddy/Caddyfile 的实例。
#
# 占位符：
#   {$RCLAUDE_DOMAIN}    对外域名，例如 rclaude.example.com
#   {$RCLAUDE_UPSTREAM}  本机明文 h2c 后端，例如 127.0.0.1:7969
#
# 关键点：
#   - reverse_proxy 必须用 h2c 回源（versions h2c），否则 Caddy 默认以 HTTP/1.1
#     回源，gRPC 直接失败。
#   - 不要给这条流设 response_header_timeout 或读写超时：RemotePTY/RemoteFS 都是
#     常驻双向流，交互式 PTY 可长时间空闲，任何流级超时都会把它掐断。

{$RCLAUDE_DOMAIN} {
	reverse_proxy h2c://{$RCLAUDE_UPSTREAM} {
		transport http {
			versions h2c
			dial_timeout 5s
		}
	}

	# ---- 证书方案（三选一，由 install-caddy.sh 的 RCLAUDE_TLS_MODE 决定）----
	#
	# 方案 A：自动 HTTPS（Let's Encrypt，公网可信）。
	#   前提：{$RCLAUDE_DOMAIN} 的 DNS 直连本源站（Cloudflare 需为 DNS only 灰云），
	#   且 80/443 可从公网到达本机。此时本块不需要任何 tls 指令，删除下面两行即可，
	#   客户端 server.tls 不填 ca_file（用系统根）。
	#
	# 方案 B：内部 CA（Caddy 本地 CA，自签，绕开 CDN/无需公网 ACME）。
	#   客户端把 Caddy 根 CA 填到 server.tls.ca_file，并让 server_name = 本域名。
	#   install-caddy.sh 在 RCLAUDE_TLS_MODE=internal 时注入下面这行：
	# tls internal
}
